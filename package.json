{
  "name": "rok-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "postinstall": "prisma generate",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:secrets": "node scripts/secret-scan.mjs",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e",
    "test:ocr-regression": "vitest run tests/regression",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "backfill:aliases": "tsx scripts/backfill-governor-aliases.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1030.0",
    "@aws-sdk/client-lambda": "^3.1029.0",
    "@aws-sdk/client-sqs": "^3.1029.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@vercel/blob": "^2.3.3",
    "@vercel/postgres": "^0.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "google-auth-library": "^9.15.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.542.0",
    "next": "^16.2.3",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.2.3",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
