{
  "name": "rok-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "postinstall": "prisma generate",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:secrets": "node scripts/secret-scan.mjs",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e",
    "test:ocr-regression": "vitest run tests/regression",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@vercel/blob": "^2.3.3",
    "@vercel/postgres": "^0.10.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "next": "^16.2.3",
    "pg": "^8.16.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "tesseract.js": "^7.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.2.3",
    "prisma": "^7.7.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
