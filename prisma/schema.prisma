generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Governor {
  id                                  String                     @id @default(cuid())
  governorId                          String                     @unique
  name                                String
  alliance                            String                     @default("")
  workspaceId                         String?
  createdAt                           DateTime                   @default(now())
  updatedAt                           DateTime                   @updatedAt
  snapshots                           Snapshot[]
  workspace                           Workspace?                 @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  anomalies                           Anomaly[]
  aliases                             GovernorAlias[]
  rankingRows                         RankingRow[]
  rankingSnapshots                    RankingSnapshot[]
  metricObservations                  MetricObservation[]
  metricSyncBacklog                   MetricSyncBacklog[]
  assistantPendingIdentityResolutions AssistantPendingIdentity[] @relation("AssistantPendingIdentityResolvedGovernor")

  @@index([governorId])
  @@index([name])
  @@index([workspaceId])
}

enum EventType {
  KVK_START
  KVK_END
  MGE
  OSIRIS
  WEEKLY
  CUSTOM
}

model Event {
  id                         String                     @id @default(cuid())
  name                       String
  description                String?
  eventType                  EventType                  @default(CUSTOM)
  workspaceId                String?
  weekKey                    String?
  startsAt                   DateTime?
  endsAt                     DateTime?
  isAutoGenerated            Boolean                    @default(false)
  isClosed                   Boolean                    @default(false)
  createdAt                  DateTime                   @default(now())
  snapshots                  Snapshot[]
  workspace                  Workspace?                 @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  scanJobs                   ScanJob[]
  rankingRuns                RankingRun[]
  ingestionTasks             IngestionTask[]
  rankingSnapshots           RankingSnapshot[]
  metricObservations         MetricObservation[]
  metricSyncBacklog          MetricSyncBacklog[]        @relation("MetricSyncBacklogEvent")
  assistantPendingIdentities AssistantPendingIdentity[]
  reportSnapshotsAsA         ReportSnapshot[]           @relation("ReportEventA")
  reportSnapshotsAsB         ReportSnapshot[]           @relation("ReportEventB")
  exportJobsAsA              ExportJob[]                @relation("ExportEventA")
  exportJobsAsB              ExportJob[]                @relation("ExportEventB")

  @@unique([workspaceId, eventType, weekKey])
  @@index([createdAt])
  @@index([workspaceId])
  @@index([workspaceId, eventType, createdAt])
  @@index([workspaceId, weekKey])
}

model Snapshot {
  id            String             @id @default(cuid())
  eventId       String
  governorId    String
  workspaceId   String?
  event         Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  governor      Governor           @relation(fields: [governorId], references: [id], onDelete: Cascade)
  workspace     Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  power         BigInt
  killPoints    BigInt
  t4Kills       BigInt             @default(0)
  t5Kills       BigInt             @default(0)
  deads         BigInt
  screenshotUrl String?
  ocrConfidence Float              @default(0)
  verified      Boolean            @default(false)
  createdAt     DateTime           @default(now())
  artifacts     Artifact[]
  revisions     SnapshotRevision[]
  anomalies     Anomaly[]

  @@unique([eventId, governorId])
  @@index([eventId])
  @@index([governorId])
  @@index([workspaceId])
}

model KingdomSettings {
  id                String   @id @default("default")
  t4Weight          Float    @default(0.5)
  t5Weight          Float    @default(1.0)
  deadWeight        Float    @default(5.0)
  kpPerPowerRatio   Float    @default(0.3) // Expect 300k KP per 1M power
  deadPerPowerRatio Float    @default(0.02) // Expect 20k Deads per 1M power
  discordWebhook    String?
  updatedAt         DateTime @updatedAt
}

model Workspace {
  id                         String                     @id @default(cuid())
  slug                       String                     @unique
  name                       String
  kingdomTag                 String?
  description                String?
  isArchived                 Boolean                    @default(false)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  governors                  Governor[]
  events                     Event[]
  snapshots                  Snapshot[]
  settings                   WorkspaceSettings?
  accessLinks                AccessLink[]
  scanJobs                   ScanJob[]
  artifacts                  Artifact[]
  revisions                  SnapshotRevision[]
  anomalies                  Anomaly[]
  exportJobs                 ExportJob[]
  reportSnapshots            ReportSnapshot[]
  deliveryLogs               DeliveryLog[]
  idempotencyKeys            IdempotencyKey[]
  ocrProfiles                OcrProfile[]
  ocrCorrectionLogs          OcrCorrectionLog[]
  ocrFallbackUsage           OcrFallbackUsage[]
  ocrGoldenFixtures          OcrGoldenFixture[]
  rankingRuns                RankingRun[]
  rankingRows                RankingRow[]
  rankingSnapshots           RankingSnapshot[]
  rankingRevisions           RankingRevision[]
  governorAliases            GovernorAlias[]
  ingestionTasks             IngestionTask[]
  activityStandards          AllianceActivityStandard[]
  metricObservations         MetricObservation[]
  metricSyncBacklog          MetricSyncBacklog[]
  assistantConversations     AssistantConversation[]
  assistantMessages          AssistantMessage[]
  assistantPlans             AssistantPlan[]
  assistantActions           AssistantAction[]
  assistantPendingIdentities AssistantPendingIdentity[]
  embeddingDocuments         EmbeddingDocument[]
  embeddingTasks             EmbeddingTask[]

  @@index([createdAt])
}

enum ActivityMetricKey {
  POWER_GROWTH
  CONTRIBUTION_POINTS
  FORT_DESTROYING
  KILL_POINTS_GROWTH
}

model AllianceActivityStandard {
  id            String            @id @default(cuid())
  workspaceId   String
  allianceTag   String
  allianceLabel String
  metricKey     ActivityMetricKey
  minimumValue  BigInt
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, allianceTag, metricKey])
  @@index([workspaceId, isActive, metricKey])
}

model WorkspaceSettings {
  id                          String    @id @default(cuid())
  workspaceId                 String    @unique
  t4Weight                    Float     @default(0.5)
  t5Weight                    Float     @default(1.0)
  deadWeight                  Float     @default(5.0)
  kpPerPowerRatio             Float     @default(0.3)
  deadPerPowerRatio           Float     @default(0.02)
  discordWebhook              String?
  fallbackOcrEnabled          Boolean   @default(true)
  fallbackOcrDailyLimit       Int       @default(50)
  fallbackOcrMonthlyBudgetUsd Float     @default(5)
  fallbackOcrProvider         String    @default("google_vision")
  fallbackOcrModel            String    @default("DOCUMENT_TEXT_DETECTION")
  ocrEngine                   String    @default("mistral")
  ocrModel                    String    @default("mistral-ocr-latest")
  assistantEnabled            Boolean   @default(true)
  assistantModel              String    @default("mistral-large-latest")
  assistantConfig             Json?
  assistantLogRetentionDays   Int       @default(180)
  featureAdbCaptureRnd        Boolean   @default(false)
  weekResetUtcOffset          String    @default("+00:00")
  updatedAt                   DateTime  @updatedAt
  workspace                   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

model AccessLink {
  id                                  String                     @id @default(cuid())
  workspaceId                         String
  role                                WorkspaceRole              @default(VIEWER)
  label                               String?
  tokenHash                           String                     @unique
  createdAt                           DateTime                   @default(now())
  expiresAt                           DateTime?
  revokedAt                           DateTime?
  lastUsedAt                          DateTime?
  workspace                           Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  revisions                           SnapshotRevision[]
  reportSnapshots                     ReportSnapshot[]
  correctionLogs                      OcrCorrectionLog[]         @relation("OcrCorrectionReviewedBy")
  rankingRunsCreated                  RankingRun[]               @relation("RankingRunCreatedBy")
  rankingRowsReviewed                 RankingRow[]               @relation("RankingRowReviewedBy")
  rankingRevisionsChanged             RankingRevision[]          @relation("RankingRevisionChangedBy")
  assistantConversations              AssistantConversation[]    @relation("AssistantConversationAccessLink")
  assistantPlansCreated               AssistantPlan[]            @relation("AssistantPlanCreatedBy")
  assistantPendingIdentitiesRequested AssistantPendingIdentity[] @relation("AssistantPendingIdentityRequestedBy")
  assistantPendingIdentitiesResolved  AssistantPendingIdentity[] @relation("AssistantPendingIdentityResolvedBy")

  @@index([workspaceId])
  @@index([expiresAt])
}

model AssistantConversation {
  id                    String                      @id @default(cuid())
  workspaceId           String
  accessLinkId          String?
  title                 String?
  mistralConversationId String?
  status                AssistantConversationStatus @default(ACTIVE)
  model                 String?
  metadata              Json?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  archivedAt            DateTime?
  workspace             Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accessLink            AccessLink?                 @relation("AssistantConversationAccessLink", fields: [accessLinkId], references: [id], onDelete: SetNull)
  messages              AssistantMessage[]
  plans                 AssistantPlan[]
  pendingIdentities     AssistantPendingIdentity[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, status, updatedAt])
  @@index([mistralConversationId])
}

model AssistantMessage {
  id             String                @id @default(cuid())
  conversationId String
  workspaceId    String
  role           AssistantMessageRole
  content        String
  attachments    Json?
  model          String?
  mistralEntryId String?
  mistralPayload Json?
  createdAt      DateTime              @default(now())
  conversation   AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace      Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([workspaceId, createdAt])
}

model AssistantPlan {
  id                String                     @id @default(cuid())
  conversationId    String
  workspaceId       String
  createdByLinkId   String?
  summary           String
  status            AssistantPlanStatus        @default(PENDING)
  actionsJson       Json
  confirmationToken String?
  confirmedAt       DateTime?
  executedAt        DateTime?
  deniedAt          DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  conversation      AssistantConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace         Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByLink     AccessLink?                @relation("AssistantPlanCreatedBy", fields: [createdByLinkId], references: [id], onDelete: SetNull)
  actions           AssistantAction[]
  pendingIdentities AssistantPendingIdentity[]

  @@unique([workspaceId, confirmationToken])
  @@index([conversationId, createdAt])
  @@index([workspaceId, status, createdAt])
}

model AssistantAction {
  id          String                @id @default(cuid())
  planId      String
  workspaceId String
  actionType  AssistantActionType
  actionIndex Int
  status      AssistantActionStatus @default(PENDING)
  request     Json
  result      Json?
  error       String?
  executedAt  DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  plan        AssistantPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([planId, actionIndex])
  @@index([workspaceId, actionType, createdAt])
}

model AssistantPendingIdentity {
  id                   String                         @id @default(cuid())
  workspaceId          String
  conversationId       String?
  planId               String?
  requestedByLinkId    String?
  status               AssistantPendingIdentityStatus @default(PENDING)
  reason               String?
  governorIdRaw        String?
  governorNameRaw      String
  eventId              String?
  payload              Json
  candidateGovernorIds Json?
  resolvedGovernorId   String?
  resolvedByLinkId     String?
  resolutionNote       String?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt
  resolvedAt           DateTime?
  workspace            Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation         AssistantConversation?         @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  plan                 AssistantPlan?                 @relation(fields: [planId], references: [id], onDelete: SetNull)
  event                Event?                         @relation(fields: [eventId], references: [id], onDelete: SetNull)
  resolvedGovernor     Governor?                      @relation("AssistantPendingIdentityResolvedGovernor", fields: [resolvedGovernorId], references: [id], onDelete: SetNull)
  requestedByLink      AccessLink?                    @relation("AssistantPendingIdentityRequestedBy", fields: [requestedByLinkId], references: [id], onDelete: SetNull)
  resolvedByLink       AccessLink?                    @relation("AssistantPendingIdentityResolvedBy", fields: [resolvedByLinkId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, governorIdRaw])
  @@index([conversationId, createdAt])
}

enum ScanJobStatus {
  QUEUED
  PROCESSING
  REVIEW
  READY
  COMPLETED
  FAILED
  CANCELED
}

enum ScanJobSource {
  MANUAL_UPLOAD
  ADB_RND
}

model ScanJob {
  id                 String              @id @default(cuid())
  workspaceId        String
  eventId            String?
  status             ScanJobStatus       @default(QUEUED)
  source             ScanJobSource       @default(MANUAL_UPLOAD)
  idempotencyKey     String?
  totalFiles         Int                 @default(0)
  processedFiles     Int                 @default(0)
  lowConfidenceFiles Int                 @default(0)
  notes              String?
  error              String?
  createdAt          DateTime            @default(now())
  startedAt          DateTime?
  completedAt        DateTime?
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  event              Event?              @relation(fields: [eventId], references: [id], onDelete: SetNull)
  ocrExtractions     OcrExtraction[]
  artifacts          Artifact[]
  ingestionTasks     IngestionTask[]
  metricSyncBacklog  MetricSyncBacklog[]

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([createdAt])
}

enum ArtifactType {
  SCREENSHOT
  OCR_CROP
  REPORT_CSV
  REPORT_XLSX
  REPORT_JSON
}

model Artifact {
  id             String             @id @default(cuid())
  workspaceId    String
  scanJobId      String?
  snapshotId     String?
  type           ArtifactType
  url            String
  checksum       String?
  bytes          Int?
  metadata       Json?
  createdAt      DateTime           @default(now())
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scanJob        ScanJob?           @relation(fields: [scanJobId], references: [id], onDelete: SetNull)
  snapshot       Snapshot?          @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  ocrExtractions OcrExtraction[]
  exportJobs     ExportJob[]
  goldenFixtures OcrGoldenFixture[]
  rankingRuns    RankingRun[]
  ingestionTasks IngestionTask[]

  @@index([workspaceId, type])
  @@index([scanJobId])
  @@index([snapshotId])
}

enum OcrProvider {
  MISTRAL
  TESSERACT
  FALLBACK
  MANUAL
}

enum OcrExtractionStatus {
  RAW
  REVIEWED
  APPROVED
  REJECTED
}

enum IngestionDomain {
  PROFILE_SNAPSHOT
  RANKING_CAPTURE
}

enum RankingRunStatus {
  RAW
  REVIEW
  MERGED
  FAILED
}

enum RankingIdentityStatus {
  UNRESOLVED
  AUTO_LINKED
  MANUAL_LINKED
  REJECTED
}

enum RankingSnapshotStatus {
  ACTIVE
  UNRESOLVED
  REJECTED
}

enum RankingRowReviewAction {
  LINK_TO_GOVERNOR
  CREATE_ALIAS
  CORRECT_ROW
  REJECT_ROW
  SYSTEM_MERGE
}

enum IngestionTaskStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum MetricObservationSourceType {
  PROFILE
  RANKBOARD
}

enum MetricSyncBacklogStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AssistantConversationStatus {
  ACTIVE
  ARCHIVED
}

enum AssistantMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum AssistantPlanStatus {
  PENDING
  CONFIRMED
  EXECUTED
  DENIED
  FAILED
}

enum AssistantActionStatus {
  PENDING
  EXECUTED
  FAILED
  SKIPPED
}

enum AssistantActionType {
  REGISTER_PLAYER
  UPDATE_PLAYER
  DELETE_PLAYER
  CREATE_EVENT
  DELETE_EVENT
  RECORD_PROFILE_STATS
}

enum AssistantPendingIdentityStatus {
  PENDING
  RESOLVED
  DENIED
}

enum EmbeddingCorpus {
  GOVERNOR_IDENTITY
  EVENTS
  OCR_EXTRACTIONS
  RANKING
  ASSISTANT_AUDIT
}

enum EmbeddingTaskOperation {
  UPSERT
  DELETE
  BACKFILL
}

enum EmbeddingTaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model EmbeddingDocument {
  id         String          @id @default(cuid())
  workspaceId String
  corpus     EmbeddingCorpus
  entityType String
  entityId   String
  chunkIndex Int
  content    String
  contentHash String
  model      String
  dimensions Int
  embedding  Unsupported("vector")
  metadata   Json?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  workspace  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, corpus, entityType, entityId, chunkIndex, model])
  @@index([workspaceId, corpus, entityType, entityId])
  @@index([workspaceId, corpus, createdAt])
}

model EmbeddingTask {
  id          String                 @id @default(cuid())
  workspaceId String
  corpus      EmbeddingCorpus
  operation   EmbeddingTaskOperation
  entityType  String
  entityId    String?
  payload     Json?
  status      EmbeddingTaskStatus    @default(PENDING)
  attemptCount Int                   @default(0)
  availableAt DateTime               @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  lastError   String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, availableAt, createdAt])
  @@index([workspaceId, corpus, entityType, entityId])
  @@index([status, availableAt])
}

model IngestionTask {
  id             String              @id @default(cuid())
  workspaceId    String
  scanJobId      String
  artifactId     String
  eventId        String?
  status         IngestionTaskStatus @default(QUEUED)
  archetypeHint  String?
  attemptCount   Int                 @default(0)
  lastError      String?
  startedAt      DateTime?
  completedAt    DateTime?
  idempotencyKey String?
  metadata       Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scanJob        ScanJob             @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  artifact       Artifact            @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  event          Event?              @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, idempotencyKey])
  @@unique([scanJobId, artifactId])
  @@index([workspaceId, status, createdAt])
  @@index([scanJobId, createdAt])
  @@index([scanJobId, status, createdAt])
  @@index([artifactId])
}

model OcrExtraction {
  id                 String              @id @default(cuid())
  scanJobId          String
  artifactId         String?
  provider           OcrProvider         @default(TESSERACT)
  status             OcrExtractionStatus @default(RAW)
  profileId          String?
  governorIdRaw      String?
  governorNameRaw    String?
  confidence         Float               @default(0)
  engineVersion      String?             @default("v2")
  lowConfidence      Boolean             @default(false)
  failureReasons     Json?
  fields             Json
  normalized         Json?
  validation         Json?
  preprocessingTrace Json?
  candidates         Json?
  fusionDecision     Json?
  correctionLogs     OcrCorrectionLog[]
  metricSyncBacklog  MetricSyncBacklog[]
  createdAt          DateTime            @default(now())
  scanJob            ScanJob             @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  artifact           Artifact?           @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  profile            OcrProfile?         @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([scanJobId, status])
  @@index([scanJobId, status, createdAt])
  @@index([profileId])
  @@index([lowConfidence])
}

model OcrProfile {
  id               String             @id @default(cuid())
  workspaceId      String
  profileKey       String
  name             String
  version          Int                @default(1)
  isDefault        Boolean            @default(false)
  isActive         Boolean            @default(true)
  sourceTemplateId String?
  minWidth         Int?
  maxWidth         Int?
  minAspectRatio   Float?
  maxAspectRatio   Float?
  calibration      Json
  regions          Json
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  workspace        Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  extractions      OcrExtraction[]
  fixtures         OcrGoldenFixture[]

  @@unique([workspaceId, profileKey, version])
  @@index([workspaceId, isActive])
}

model GovernorAlias {
  id              String    @id @default(cuid())
  workspaceId     String
  governorId      String
  aliasRaw        String
  aliasNormalized String
  confidence      Float     @default(1)
  source          String    @default("manual")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  governor        Governor  @relation(fields: [governorId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, aliasNormalized])
  @@index([governorId])
  @@index([workspaceId, createdAt])
}

model RankingRun {
  id                 String            @id @default(cuid())
  workspaceId        String
  eventId            String?
  artifactId         String?
  createdByLinkId    String?
  domain             IngestionDomain   @default(RANKING_CAPTURE)
  rankingType        String
  metricKey          String
  headerText         String?
  source             ScanJobSource     @default(MANUAL_UPLOAD)
  status             RankingRunStatus  @default(RAW)
  idempotencyKey     String?
  captureFingerprint String?
  dedupeHash         String?
  metadata           Json?
  notes              String?
  error              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  processedAt        DateTime?
  workspace          Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  event              Event?            @relation(fields: [eventId], references: [id], onDelete: SetNull)
  artifact           Artifact?         @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  createdByLink      AccessLink?       @relation("RankingRunCreatedBy", fields: [createdByLinkId], references: [id], onDelete: SetNull)
  rows               RankingRow[]
  snapshots          RankingSnapshot[]
  revisions          RankingRevision[]

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, eventId, createdAt])
  @@index([workspaceId, rankingType, status])
  @@index([captureFingerprint])
}

model RankingRow {
  id                     String                @id @default(cuid())
  workspaceId            String
  runId                  String
  governorId             String?
  reviewedByLinkId       String?
  sourceRank             Int?
  governorNameRaw        String
  governorNameNormalized String
  allianceRaw            String?
  titleRaw               String?
  metricRaw              String
  metricValue            BigInt
  confidence             Float                 @default(0)
  identityStatus         RankingIdentityStatus @default(UNRESOLVED)
  rowHash                String
  ocrTrace               Json?
  candidates             Json?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  workspace              Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  run                    RankingRun            @relation(fields: [runId], references: [id], onDelete: Cascade)
  governor               Governor?             @relation(fields: [governorId], references: [id], onDelete: SetNull)
  reviewedByLink         AccessLink?           @relation("RankingRowReviewedBy", fields: [reviewedByLinkId], references: [id], onDelete: SetNull)
  snapshots              RankingSnapshot[]
  revisions              RankingRevision[]

  @@unique([runId, rowHash])
  @@index([workspaceId, identityStatus, createdAt])
  @@index([workspaceId, runId, identityStatus, createdAt])
  @@index([workspaceId, governorNameNormalized])
  @@index([runId, sourceRank])
}

model RankingSnapshot {
  id                     String                @id @default(cuid())
  workspaceId            String
  eventId                String
  rankingType            String
  metricKey              String
  identityKey            String
  governorId             String?
  governorNameRaw        String
  governorNameNormalized String
  sourceRank             Int?
  metricValue            BigInt
  status                 RankingSnapshotStatus @default(ACTIVE)
  lastRunId              String?
  lastRowId              String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  workspace              Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  event                  Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  governor               Governor?             @relation(fields: [governorId], references: [id], onDelete: SetNull)
  lastRun                RankingRun?           @relation(fields: [lastRunId], references: [id], onDelete: SetNull)
  lastRow                RankingRow?           @relation(fields: [lastRowId], references: [id], onDelete: SetNull)
  revisions              RankingRevision[]

  @@unique([workspaceId, eventId, rankingType, identityKey])
  @@index([workspaceId, eventId, rankingType, status])
  @@index([workspaceId, eventId, rankingType, metricKey, status, metricValue, sourceRank, governorNameNormalized])
  @@index([workspaceId, metricValue, sourceRank, governorNameNormalized])
}

model RankingRevision {
  id              String                 @id @default(cuid())
  workspaceId     String
  snapshotId      String
  runId           String?
  rowId           String?
  changedByLinkId String?
  action          RankingRowReviewAction @default(SYSTEM_MERGE)
  reason          String?
  previousData    Json?
  nextData        Json
  createdAt       DateTime               @default(now())
  workspace       Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snapshot        RankingSnapshot        @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  run             RankingRun?            @relation(fields: [runId], references: [id], onDelete: SetNull)
  row             RankingRow?            @relation(fields: [rowId], references: [id], onDelete: SetNull)
  changedByLink   AccessLink?            @relation("RankingRevisionChangedBy", fields: [changedByLinkId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([snapshotId, createdAt])
}

model MetricObservation {
  id          String                      @id @default(cuid())
  workspaceId String
  eventId     String
  governorId  String
  metricKey   String
  metricValue BigInt
  sourceType  MetricObservationSourceType
  sourceRank  Int?
  sourceRefId String?
  observedAt  DateTime
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  workspace   Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  event       Event                       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  governor    Governor                    @relation(fields: [governorId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, eventId, governorId, metricKey])
  @@index([workspaceId, eventId, metricKey, sourceType])
  @@index([workspaceId, governorId, metricKey, observedAt])
}

model MetricSyncBacklog {
  id              String                  @id @default(cuid())
  workspaceId     String
  scanJobId       String?
  extractionId    String?
  governorId      String?
  linkedEventId   String?
  governorGameId  String
  governorNameRaw String
  power           BigInt
  killPoints      BigInt
  t4Kills         BigInt                  @default(0)
  t5Kills         BigInt                  @default(0)
  deads           BigInt                  @default(0)
  status          MetricSyncBacklogStatus @default(PENDING)
  attemptCount    Int                     @default(0)
  sourceRefId     String?
  observedAt      DateTime
  processedAt     DateTime?
  lastError       String?
  metadata        Json?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  workspace       Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scanJob         ScanJob?                @relation(fields: [scanJobId], references: [id], onDelete: SetNull)
  extraction      OcrExtraction?          @relation(fields: [extractionId], references: [id], onDelete: SetNull)
  governor        Governor?               @relation(fields: [governorId], references: [id], onDelete: SetNull)
  linkedEvent     Event?                  @relation("MetricSyncBacklogEvent", fields: [linkedEventId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, extractionId])
  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, linkedEventId, status])
  @@index([scanJobId, createdAt])
}

model OcrCorrectionLog {
  id               String        @id @default(cuid())
  workspaceId      String
  extractionId     String
  reviewedByLinkId String?
  fieldName        String
  previousValue    String?
  correctedValue   String
  reasonCode       String?
  confidence       Float?
  createdAt        DateTime      @default(now())
  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  extraction       OcrExtraction @relation(fields: [extractionId], references: [id], onDelete: Cascade)
  reviewedByLink   AccessLink?   @relation("OcrCorrectionReviewedBy", fields: [reviewedByLinkId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([fieldName, createdAt])
}

model OcrFallbackUsage {
  id           String    @id @default(cuid())
  workspaceId  String
  periodMonth  String
  requestCount Int       @default(0)
  projectedUsd Float     @default(0)
  blocked      Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, periodMonth])
  @@index([workspaceId, updatedAt])
}

model OcrGoldenFixture {
  id          String      @id @default(cuid())
  workspaceId String
  artifactId  String
  profileId   String?
  label       String?
  expected    Json
  metadata    Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  artifact    Artifact    @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  profile     OcrProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, artifactId])
  @@index([workspaceId, createdAt])
}

model SnapshotRevision {
  id              String      @id @default(cuid())
  workspaceId     String
  snapshotId      String
  changedByLinkId String?
  reason          String?
  previousData    Json
  nextData        Json
  createdAt       DateTime    @default(now())
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snapshot        Snapshot    @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  changedByLink   AccessLink? @relation(fields: [changedByLinkId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([snapshotId])
}

enum AnomalySeverity {
  INFO
  WARNING
  ERROR
}

model Anomaly {
  id          String          @id @default(cuid())
  workspaceId String
  snapshotId  String?
  governorId  String?
  eventAId    String?
  eventBId    String?
  code        String
  type        String
  message     String
  severity    AnomalySeverity @default(WARNING)
  context     Json?
  resolved    Boolean         @default(false)
  createdAt   DateTime        @default(now())
  resolvedAt  DateTime?
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snapshot    Snapshot?       @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  governor    Governor?       @relation(fields: [governorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([severity, resolved])
}

enum ExportJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
}

model ExportJob {
  id               String          @id @default(cuid())
  workspaceId      String
  eventAId         String?
  eventBId         String?
  status           ExportJobStatus @default(QUEUED)
  format           String          @default("xlsx")
  idempotencyKey   String?
  request          Json?
  resultArtifactId String?
  error            String?
  createdAt        DateTime        @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  expiresAt        DateTime?
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  eventA           Event?          @relation("ExportEventA", fields: [eventAId], references: [id], onDelete: SetNull)
  eventB           Event?          @relation("ExportEventB", fields: [eventBId], references: [id], onDelete: SetNull)
  resultArtifact   Artifact?       @relation(fields: [resultArtifactId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, status])
}

model ReportSnapshot {
  id              String      @id @default(cuid())
  workspaceId     String
  shareSlug       String      @unique
  eventAId        String
  eventBId        String
  createdByLinkId String?
  payload         Json
  createdAt       DateTime    @default(now())
  expiresAt       DateTime?
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  eventA          Event       @relation("ReportEventA", fields: [eventAId], references: [id], onDelete: Cascade)
  eventB          Event       @relation("ReportEventB", fields: [eventBId], references: [id], onDelete: Cascade)
  createdByLink   AccessLink? @relation(fields: [createdByLinkId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
}

enum DeliveryStatus {
  PENDING
  RETRYING
  SENT
  FAILED
}

model DeliveryLog {
  id              String         @id @default(cuid())
  workspaceId     String
  integration     String
  destinationHash String
  payload         Json
  status          DeliveryStatus @default(PENDING)
  attemptCount    Int            @default(0)
  nextAttemptAt   DateTime?
  lastError       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, nextAttemptAt])
}

model IdempotencyKey {
  id          String    @id @default(cuid())
  workspaceId String
  scope       String
  keyHash     String
  requestHash String
  response    Json?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, scope, keyHash])
  @@index([expiresAt])
}
