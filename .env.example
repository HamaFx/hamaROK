# Vercel Postgres (auto-populated by Vercel after adding Storage)
POSTGRES_PRISMA_URL="postgresql://user:password@host:5432/dbname?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/dbname?sslmode=require"

# Vercel Blob (auto-populated by Vercel after adding Blob storage)
# Keep this empty in local if uploads are not required.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_replace_me"

# Application URL used for share links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Security: used to hash access tokens and idempotency keys
APP_SIGNING_SECRET="replace-with-random-32-char-secret"

# Optional OCR fallback provider credentials
OPENAI_API_KEY=""
MISTRAL_API_KEY=""
MISTRAL_BASE_URL="https://api.mistral.ai"
OCR_ENGINE="mistral"
GOOGLE_VISION_API_KEY=""
GOOGLE_APPLICATION_CREDENTIALS=""
GOOGLE_VISION_SERVICE_ACCOUNT_JSON=""

# Optional AWS OCR worker control (scale-to-zero queue + start lambda)
AWS_REGION="us-east-1"
AWS_OCR_CONTROL_ENABLED="false"
AWS_OCR_QUEUE_URL=""
AWS_OCR_START_LAMBDA=""
AWS_OCR_STOP_LAMBDA=""
AWS_OCR_INSTANCE_ID=""
UPLOAD_MODE="queue_first"
# Only needed when running on platforms without IAM role-based auth (e.g., Vercel)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Feature flags (advanced v2)
OCR_FALLBACK_ENABLED="false"
OCR_FALLBACK_DAILY_LIMIT="50"
FEATURE_ADB_CAPTURE_RND="false"
FEATURE_METRICS_LOGGING="true"

# Optional runtime strictness
REQUIRE_BLOB_UPLOAD="false"
